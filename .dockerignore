# ============================================================
# .dockerignore — 告诉 Docker 构建时忽略哪些文件
# ============================================================
#
# 作用：类似 .gitignore，但针对 docker build 的上下文。
# 当执行 docker build . 时，Docker 会把当前目录（.）打包成
# "构建上下文"发送给 Docker 守护进程。
# .dockerignore 里的文件不会被发送，有两个好处：
#   1. 减小构建上下文体积，加快 docker build 速度
#   2. 防止敏感文件（如 .env）意外打进镜像

# ── 敏感文件（绝对不能打进镜像）────────────────────────────
.env
*.key
*.pem
secrets/

# ── 向量数据库（容器启动时自动生成，用 volume 挂载持久化）──
medical_kb_store/

# ── Python 缓存（构建产物，不需要）─────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
.pytest_cache/

# ── 虚拟环境（容器内用系统 Python，不需要 venv）────────────
.venv/
venv/
env/

# ── Git 相关（源码管理文件，运行时不需要）──────────────────
.git/
.gitignore

# ── IDE 配置（开发工具配置，运行时不需要）──────────────────
.vscode/
.idea/
*.swp
*.swo

# ── 开发/文档文件（运行时不需要）───────────────────────────
*.md
assets/

# ── macOS 系统文件 ────────────────────────────────────────
.DS_Store
